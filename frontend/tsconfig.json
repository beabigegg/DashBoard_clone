{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "allowJs": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/core/**/*", "src/shared-composables/**/*", "src/shared-ui/**/*", "src/admin-shared/**/*", "src/resource-shared/**/*", "src/wip-shared/**/*", "src/reject-history/**/*", "src/hold-history/**/*", "src/wip-overview/**/*", "src/wip-detail/**/*", "src/hold-overview/**/*", "src/hold-detail/**/*", "src/resource-status/**/*", "src/qc-gate/**/*", "src/resource-history/**/*", "src/job-query/**/*", "src/production-history/**/*", "src/query-tool/**/*", "src/material-trace/**/*", "src/mid-section-defect/**/*"],
  "exclude": ["node_modules", "dist"]
}
