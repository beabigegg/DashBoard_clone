# ============================================================
# MES Dashboard Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#   nano .env
#
# Deployment Mode: DEV | PRD
# ─────────────────────────────────────────────────────────────
# DEV: 開發/測試用，單人使用
#      最低硬體: 2+ cores, 8GB RAM
#
# PRD: 正式上線，50 人使用 / 10-12 人同時在線
#      最低硬體: 4+ cores, 12GB RAM, SSD 50GB+
#      建議硬體: 4+ cores, 16GB RAM, SSD 50GB+ (有充足餘裕可擴展至 80 人)
#
# ── 容量規劃 (PRD, 4 workers) ────────────────────────────────
#   Gunicorn workers:  4 × ~1050 MB  =  4,200 MB
#   RQ workers (×3):   3 ×  ~200 MB  =    600 MB
#   Redis:                               768 MB
#   OS + kernel:                         ~500 MB
#   ────────────────────────────────────────────
#   穩態合計:                          ~6,068 MB
#   瞬態峰值 (cache 序列化/大查詢):   +2,000 MB
#   ────────────────────────────────────────────
#   最低 RAM = 8,068 / 0.8 ≈ 12 GB (安全水位 80%)
#   建議 RAM = 16 GB (穩態 37%, 峰值 50%, 可擴展至 80 人)
#
# 切換方式：僅需調整底部「資源配置」區塊的值
# 其餘設定（資料庫、認證、功能開關等）DEV 與 PRD 完全相同
# ============================================================

FLASK_ENV=production
FLASK_DEBUG=0

# ============================================================
# [SHARED] Database Configuration (REQUIRED)
# ============================================================
# Oracle Database connection settings — DEV/PRD 共用同一正式資料庫
DB_HOST=your_database_host
DB_PORT=1521
DB_SERVICE=your_service_name
DB_USER=your_username
DB_PASSWORD=your_password

# ============================================================
# [SHARED] Authentication Configuration
# ============================================================
# LDAP API endpoint for user authentication
LDAP_API_URL=https://your-ldap-api-endpoint.example.com

# Admin email addresses (comma-separated for multiple)
ADMIN_EMAILS=admin@example.com

# Local Authentication (for development/testing)
# Production safety: when FLASK_ENV=production, local auth is forcibly disabled
LOCAL_AUTH_ENABLED=false
LOCAL_AUTH_USERNAME=
LOCAL_AUTH_PASSWORD=

# Session Security (REQUIRED for production!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# Session timeout in seconds (default: 28800 = 8 hours)
SESSION_LIFETIME=28800
PERMANENT_SESSION_LIFETIME=28800

# Login session SQLite path
LOGIN_SESSION_SQLITE_PATH=logs/login_sessions.sqlite

# ============================================================
# [SHARED] Feature Flags & Functional Settings
# ============================================================
# Portal Shell / Modernization
PORTAL_SPA_ENABLED=true
MODERNIZATION_ENFORCE_ASSET_READINESS=true
MODERNIZATION_RETIRE_IN_SCOPE_RUNTIME_FALLBACK=true
RUNTIME_CONTRACT_ENFORCE=true
FRONTEND_BUILD_MODE=always
FRONTEND_BUILD_FAIL_ON_ERROR=true

# Circuit Breaker (database protection)
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_FAILURE_RATE=0.5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30
CIRCUIT_BREAKER_WINDOW_SIZE=10

# Performance Metrics
SLOW_QUERY_THRESHOLD=5.0
METRICS_WINDOW_SIZE=1000
HEALTH_MEMO_TTL_SECONDS=5

# SQLite Log Store
LOG_STORE_ENABLED=true
LOG_SQLITE_PATH=logs/admin_logs.sqlite
LOG_SQLITE_RETENTION_DAYS=7
LOG_SQLITE_MAX_ROWS=100000

# CORS (comma-separated origins, * for dev only)
# 注意：本專案採前後端同源單一 Port 部署架構，實際上不需要 CORS 設定。
# 此變數目前未被程式碼讀取，僅保留供未來跨域需求或反向代理情境使用。
CORS_ALLOWED_ORIGINS=

# ============================================================
# [SHARED] Redis Functional Settings
# ============================================================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
REDIS_KEY_PREFIX=mes_wip
REDIS_PERSISTENCE_ENABLED=true
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec
REDIS_SAVE="900 1 300 10 60 10000"
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_TTL_CLEANUP_ON_START=true
REDIS_TTL_CLEANUP_PATTERNS=batch:*,reject_dataset:*,hold_dataset:*,resource_dataset:*,job_query:*
CACHE_CHECK_INTERVAL=600

# ============================================================
# [SHARED] Resource Cache
# ============================================================
RESOURCE_CACHE_ENABLED=true
RESOURCE_SYNC_INTERVAL=14400
RESOURCE_INDEX_VERSION_CHECK_INTERVAL=5
REALTIME_EQUIPMENT_CACHE_ENABLED=true
EQUIPMENT_STATUS_SYNC_INTERVAL=300
FILTER_CACHE_WIP_VIEW=DWH.DW_MES_LOT_V
FILTER_CACHE_SPEC_WORKCENTER_VIEW=DWH.DW_MES_SPEC_WORKCENTER_V

# ============================================================
# [SHARED] Yield Alert Center
# ============================================================
YIELD_ALERT_CENTER_ENABLED=true
YIELD_ALERT_MAX_QUERY_DAYS=730
YIELD_ALERT_DEFAULT_PER_PAGE=50
YIELD_ALERT_MAX_PER_PAGE=200
YIELD_ALERT_CACHE_TTL_SECONDS=300
YIELD_ALERT_LINKAGE_WARN_RATIO=0.25

# ============================================================
# [SHARED] Reject History Options & Rate Limit
# ============================================================
REJECT_HISTORY_OPTIONS_CACHE_TTL_SECONDS=14400
REJECT_HISTORY_QUERY_RATE_LIMIT_MAX_REQUESTS=10
REJECT_HISTORY_QUERY_RATE_LIMIT_WINDOW_SECONDS=60
REJECT_HISTORY_OVERLOAD_RETRY_AFTER_SECONDS=30

# ============================================================
# [SHARED] Trace Pipeline Configuration
# ============================================================
TRACE_SLOW_THRESHOLD_SECONDS=15
TRACE_EVENTS_MAX_WORKERS=2
EVENT_FETCHER_MAX_WORKERS=2
EVENT_FETCHER_MAX_TOTAL_ROWS=500000
EVENT_FETCHER_ALLOW_PARTIAL_RESULTS=false
TRACE_SYNC_RSS_REJECT_MB=1100
FORWARD_PIPELINE_MAX_WORKERS=2
TRACE_EVENTS_CID_LIMIT=50000
DB_SLOW_FETCHMANY_SIZE=5000
EVENT_FETCHER_CACHE_SKIP_CID_THRESHOLD=10000
TRACE_WORKER_ENABLED=true
TRACE_JOB_TTL_SECONDS=3600
TRACE_JOB_TIMEOUT_SECONDS=1800
TRACE_WORKER_QUEUE=trace-events
TRACE_STREAM_BATCH_SIZE=5000
MATERIAL_TRACE_MAX_RESULT_MB=256

# ============================================================
# [SHARED] Async Heavy Query Worker (reject-history)
# ============================================================
REJECT_ASYNC_ENABLED=true
REJECT_WORKER_QUEUE=reject-query
REJECT_JOB_TTL_SECONDS=3600
REJECT_JOB_TIMEOUT_SECONDS=1800
RQ_REJECT_WORKER_ENABLED=true
REJECT_ENGINE_QUERY_WAIT_SECONDS=90

# [SHARED] Async Heavy Query Worker (mid-section-defect analysis)
MSD_WORKER_QUEUE=msd-analysis
MSD_JOB_TTL_SECONDS=3600
MSD_JOB_TIMEOUT_SECONDS=600
RQ_MSD_WORKER_ENABLED=true

# [SHARED] Async Heavy Query Worker (production history)
PRODUCTION_HISTORY_ASYNC_ENABLED=true
PRODUCTION_HISTORY_WORKER_QUEUE=production-history-query
PRODUCTION_HISTORY_JOB_TTL_SECONDS=3600
PRODUCTION_HISTORY_JOB_TIMEOUT_SECONDS=1800
RQ_PRODUCTION_HISTORY_WORKER_ENABLED=true

# [SHARED] Async Heavy Query Worker (yield alert)
YIELD_ALERT_ASYNC_ENABLED=true
YIELD_ALERT_WORKER_QUEUE=yield-alert-query
YIELD_ALERT_JOB_TTL_SECONDS=3600
YIELD_ALERT_JOB_TIMEOUT_SECONDS=1800
RQ_YIELD_ALERT_WORKER_ENABLED=true

# [SHARED] Async Heavy Query Worker (downtime analysis)
# env-contract §Async Worker — Downtime Query (downtime-rq-async)
DOWNTIME_ASYNC_ENABLED=true
DOWNTIME_ASYNC_DAY_THRESHOLD=30
DOWNTIME_WORKER_QUEUE=downtime-query
DOWNTIME_JOB_TIMEOUT_SECONDS=1800

# ============================================================
# [SHARED] Reject History Batch/Spill Guardrails
# ============================================================
REJECT_ENGINE_GRAIN_DAYS=5
REJECT_ENGINE_MAX_ROWS_PER_CHUNK=50000
REJECT_ENGINE_MAX_TOTAL_ROWS=200000
REJECT_ENGINE_SPILL_ENABLED=true
REJECT_ENGINE_MAX_RESULT_MB=48
QUERY_SPOOL_DIR=tmp/query_spool
REJECT_ENGINE_SPOOL_TTL_SECONDS=21600
REJECT_ENGINE_SPOOL_MAX_BYTES=2147483648
REJECT_ENGINE_SPOOL_WARN_RATIO=0.85
REJECT_ENGINE_SPOOL_CLEANUP_INTERVAL_SECONDS=300
REJECT_ENGINE_SPOOL_ORPHAN_GRACE_SECONDS=600
BATCH_QUERY_TIME_THRESHOLD_DAYS=10
BATCH_QUERY_ID_THRESHOLD=1000

# Cache-SQL runtime
REJECT_CACHE_SQL_ENABLED=true
REJECT_CACHE_SQL_BATCH_PARETO_ENABLED=true
REJECT_CACHE_SQL_VIEW_ENABLED=true
REJECT_CACHE_SQL_EXPORT_ENABLED=true
REJECT_CACHE_SQL_FALLBACK_LEGACY_ENABLED=true

# ============================================================
# [SHARED] Frontend View Compute Offload (local DuckDB-WASM)
# ============================================================
# Enable browser-side view derivation for Resource History and Hold History.
# When disabled, pages fall back to server-side /view API for all interactions.
RESOURCE_HISTORY_LOCAL_COMPUTE_ENABLED=true
# Redis TTL for immutable historical resource-history chunks (end_date < today-2d); default 86400s (24h)
RESOURCE_HISTORY_HISTORICAL_TTL=86400
# Months of resource-history data to pre-warm into Redis on service startup; 0 disables pre-warm
RESOURCE_HISTORY_PREWARM_MONTHS=3
# Redis spool metadata TTL for resource-history DuckDB cache (seconds); default 72000s (20h)
RESOURCE_HISTORY_SPOOL_TTL=72000
# Redis spool metadata TTL for downtime-analysis DuckDB cache (seconds); default 72000s (20h)
DOWNTIME_ANALYSIS_CACHE_TTL=72000
HOLD_HISTORY_LOCAL_COMPUTE_ENABLED=true
# Row-count threshold: only activate local compute when spool >= N rows
RESOURCE_SPOOL_THRESHOLD=5000
HOLD_SPOOL_THRESHOLD=5000
REJECT_CACHE_SQL_BATCH_PARETO_FALLBACK_LEGACY_ENABLED=true
REJECT_CACHE_SQL_VIEW_FALLBACK_LEGACY_ENABLED=true
REJECT_CACHE_SQL_EXPORT_FALLBACK_LEGACY_ENABLED=true

# Pareto Materialization
PARETO_MATERIALIZATION_ENABLED=false
PARETO_MATERIALIZATION_READ_ENABLED=false
PARETO_SNAPSHOT_TTL_SECONDS=600
PARETO_SNAPSHOT_MAX_CUBE_ROWS=100000
PARETO_SNAPSHOT_MAX_PAYLOAD_MB=8
PARETO_SNAPSHOT_L1_MAX_SIZE=16
PARETO_BUILD_WAIT_TIMEOUT=10

# ============================================================
# [SHARED] Input Guardrails
# ============================================================
MAX_JSON_BODY_BYTES=262144
QUERY_TOOL_RSS_REJECT_MB=1100
QUERY_TOOL_MAX_CONTAINER_IDS=200
QUERY_TOOL_SQL_BATCH_ENABLED=true
QUERY_TOOL_SPOOL_TTL_SECONDS=300
QUERY_TOOL_REJECT_INCLUDE_EXCLUDED_SCRAP=false
QUERY_TOOL_REJECT_EXCLUDE_MATERIAL_SCRAP=true
QUERY_TOOL_REJECT_EXCLUDE_PB_DIODE=true
CONTAINER_RESOLVE_INPUT_MAX_VALUES=0
CONTAINER_RESOLVE_PATTERN_MIN_PREFIX_LEN=4
CONTAINER_RESOLVE_MAX_EXPANSION_PER_TOKEN=2000
CONTAINER_RESOLVE_MAX_CONTAINER_IDS=30000
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
CSP_ALLOW_UNSAFE_EVAL=false

# ============================================================
# [SHARED] Watchdog Configuration
# ============================================================
WATCHDOG_RUNTIME_DIR=./tmp
WATCHDOG_RESTART_FLAG=./tmp/mes_dashboard_restart.flag
WATCHDOG_PID_FILE=./tmp/gunicorn.pid
WATCHDOG_STATE_FILE=./tmp/mes_dashboard_restart_state.json
WATCHDOG_RESTART_HISTORY_MAX=50
WORKER_RESTART_COOLDOWN=60
WATCHDOG_CHECK_INTERVAL=5

# ============================================================
# [SHARED] Resilience Diagnostics
# ============================================================
RESILIENCE_DEGRADED_ALERT_SECONDS=300
RESILIENCE_POOL_SATURATION_WARNING=0.90
RESILIENCE_POOL_SATURATION_CRITICAL=1.0
RESILIENCE_RESTART_CHURN_WINDOW_SECONDS=600
RESILIENCE_RESTART_CHURN_THRESHOLD=3


# ############################################################
# ############################################################
# ##                                                        ##
# ##          RESOURCE CONFIGURATION (DEV / PRD)            ##
# ##                                                        ##
# ##  僅此區塊的值在 DEV 與 PRD 模式之間不同                ##
# ##  切換模式時，將對應值替換即可                           ##
# ##                                                        ##
# ##  DEV: 單人開發, 2+ cores, 8GB RAM                      ##
# ##  PRD: 50 人, 4+ cores, 12GB+ RAM (建議 16GB), SSD 50GB ##
# ##                                                        ##
# ############################################################
# ############################################################

# ============================================================
# Gunicorn Workers & Threads
# ============================================================
#                       DEV         PRD
# workers               2           4
# threads               4           6
# 並發能力              8           24
# max_requests          5000        2000
# max_requests_jitter   1000        500
# ─────────────────────────────────────────────────────────────
# PORT equivalent: GUNICORN_BIND 即為本系統的服務監聽埠號設定，格式為 host:port
# 若只需改埠號，修改 GUNICORN_BIND 的 port 部分即可（如 0.0.0.0:9090）
GUNICORN_BIND=0.0.0.0:8080
GUNICORN_WORKERS=2                  # PRD: 4
GUNICORN_THREADS=4                  # PRD: 6
GUNICORN_TIMEOUT=360
GUNICORN_GRACEFUL_TIMEOUT=300
GUNICORN_MAX_REQUESTS=5000          # PRD: 2000
GUNICORN_MAX_REQUESTS_JITTER=1000   # PRD: 500

# ============================================================
# Database Connection Pool (Main)
# ============================================================
#                       DEV         PRD
# pool_size             5           6
# max_overflow          5           6
# per-worker 最大連線   10          12
# 全部 workers 合計     20          48
# ─────────────────────────────────────────────────────────────
DB_POOL_SIZE=5                      # PRD: 6
DB_MAX_OVERFLOW=5                   # PRD: 6
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_TCP_CONNECT_TIMEOUT=10
DB_CONNECT_RETRY_COUNT=1
DB_CONNECT_RETRY_DELAY=1.0
DB_CALL_TIMEOUT_MS=55000

# ============================================================
# Database Connection Pool (Slow Query)
# ============================================================
#                       DEV         PRD
# pool_size             2           3
# max_overflow          1           2
# max_concurrent        5           8
# ─────────────────────────────────────────────────────────────
DB_SLOW_POOL_ENABLED=true
DB_SLOW_POOL_SIZE=4                 # PRD: 6
DB_SLOW_POOL_MAX_OVERFLOW=2         # PRD: 3
DB_SLOW_POOL_TIMEOUT=30
DB_SLOW_POOL_RECYCLE=1800
DB_SLOW_CALL_TIMEOUT_MS=300000
DB_SLOW_MAX_CONCURRENT=10           # PRD: 12

# ============================================================
# Heavy Query Concurrency Control
# ============================================================
#                       DEV         PRD
# max_concurrent        3           4
# reject_threshold      4           5
# ─────────────────────────────────────────────────────────────
HEAVY_QUERY_MAX_CONCURRENT=3        # PRD: 4
HEAVY_QUERY_REJECT_THRESHOLD=4      # PRD: 5

# ============================================================
# Redis Memory
# ============================================================
#                       DEV         PRD
# maxmemory             512mb       768mb
# ─────────────────────────────────────────────────────────────
REDIS_MAXMEMORY=512mb               # PRD: 768mb

# ============================================================
# Cache TTL
# ============================================================
#                       DEV         PRD
# wip_cache_ttl         1800s       2400s (40 分鐘, 多人共享命中率更高)
# ─────────────────────────────────────────────────────────────
WIP_CACHE_TTL_SECONDS=1800          # PRD: 2400

# ============================================================
# Async Threshold (異步查詢觸發門檻)
# ============================================================
#                       DEV         PRD
# trace_cid_threshold   20000       15000
# reject_day_threshold  10          7
# ─────────────────────────────────────────────────────────────
# PRD 降低門檻，讓更多重查詢走異步路徑，減輕 worker 壓力
TRACE_ASYNC_CID_THRESHOLD=20000     # PRD: 15000
REJECT_ASYNC_DAY_THRESHOLD=10       # PRD: 7

# ============================================================
# RQ Worker Estimation (for startup memory check)
# ============================================================
# trace + reject + msd = 3 個 RQ worker processes
RQ_WORKER_COUNT_ESTIMATE=5
# RQ worker Oracle pool isolation: start_server.sh injects DB_POOL_SIZE=2
# DB_MAX_OVERFLOW=1 when launching each rq worker process.  The runtime reads
# DB_POOL_SIZE / DB_MAX_OVERFLOW directly, so those are the effective names.
# Do NOT add RQ_DB_POOL_SIZE or RQ_DB_MAX_OVERFLOW here — they are not read
# by the runtime unless database.py is updated to recognise them.

# ============================================================
# Reject Engine Parallelism
# ============================================================
#                       DEV         PRD
# parallel              3           3 (維持不變，避免 Oracle 端壓力)
# ─────────────────────────────────────────────────────────────
REJECT_ENGINE_PARALLEL=3
HOLD_ENGINE_PARALLEL=1
JOB_ENGINE_PARALLEL=1
MSD_ENGINE_PARALLEL=1
DOWNTIME_ENGINE_PARALLEL=3

# ============================================================
# Row-Count Chunking (batch-rowcount-unification)
# ============================================================
USE_ROW_COUNT_CHUNKING=false
BATCH_QUERY_ROWS_PER_CHUNK=50000

# ============================================================
# Compute Derivatives Memory Guards
# ============================================================
# DEV/PRD 維持相同，受限於 Oracle 端而非本地資源
REJECT_DERIVE_MAX_INPUT_MB=192
REJECT_DERIVE_MAX_PROJECTED_RSS_MB=1700
REJECT_DERIVE_WORKING_SET_FACTOR=1.6
REJECT_DERIVE_FORCE_GC=true
BATCH_CHUNK_MAX_MEMORY_MB=192
REJECT_QUERY_RSS_REJECT_MB=900

# ============================================================
# Worker Memory Guard (RSS OOM Prevention)
# ============================================================
#                       DEV         PRD
# rss_limit_mb          0 (auto)    2800 (基於 16GB/4w×0.7 留餘裕)
# ─────────────────────────────────────────────────────────────
WORKER_RSS_GUARD_ENABLED=true
WORKER_RSS_LIMIT_MB=0               # PRD: 2800
WORKER_RSS_WARN_RATIO=0.70
WORKER_RSS_EVICT_RATIO=0.85
WORKER_RSS_HARD_RATIO=0.95
WORKER_RSS_CHECK_INTERVAL=15
WORKER_RSS_RESTART_COOLDOWN=120

# ============================================================
# System Memory Monitoring
# ============================================================
#                       DEV         PRD
# warn_pct              85%         80%
# reject_pct            92%         90%
# ─────────────────────────────────────────────────────────────
# PRD 更早預警，保護多人環境穩定性
SYSTEM_MEM_WARN_PCT=85.0            # PRD: 80.0
SYSTEM_MEM_REJECT_PCT=92.0          # PRD: 90.0

# ============================================================
# [SHARED] AI-Assisted Reporting — Phase 1
# ============================================================
ANALYTICS_ANOMALY_DETECTION_ENABLED=false

# ============================================================
# [SHARED] AI-Assisted Reporting — Phase 2
# ============================================================
# Set AI_QUERY_ENABLED=true after configuring AI_API_KEY
AI_QUERY_ENABLED=false
AI_API_KEY=your-ai-api-key
# The following settings have sensible defaults and can be omitted:
# AI_API_URL=https://ollama_pjapi.theaken.com
# AI_MODEL=gpt-oss:120b
# AI_REQUEST_TIMEOUT=30
# AI_VERIFY_TLS=false
# AI_MAX_TOKENS=500
# AI_RATE_LIMIT_MAX_REQUESTS=3
# AI_RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# [SHARED] MySQL — Dual-Layer Sync (SQLite buffer → MySQL persistent)
# ============================================================
# Set MYSQL_OPS_ENABLED=true and fill in connection info to enable
MYSQL_OPS_ENABLED=false
# Set MYSQL_SYNC_ENABLED=false to disable SQLite→MySQL sync writes
# (useful for dev servers sharing the same MySQL to avoid write conflicts)
# MySQL reads (KPI queries, log queries) remain active when OPS is enabled.
MYSQL_SYNC_ENABLED=true
MYSQL_OPS_HOST=your_mysql_host
MYSQL_OPS_PORT=3306
MYSQL_OPS_USER=your_mysql_user
MYSQL_OPS_PASSWORD=your_mysql_password
MYSQL_OPS_DATABASE=your_mysql_database
# Optional: sync interval in seconds (default: 600 = 10 minutes)
# SYNC_WORKER_INTERVAL=600
