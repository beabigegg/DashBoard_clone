      "filter_input_semantics": ["start_date", "end_date", "sort", "page"],
      "query_payload_contract": ["start_date", "end_date"],
      "chart_data_shape": ["kpi", "pareto", "trend", "detail_table"],
      "state_contract": ["loading", "empty", "error", "success"]
    },
