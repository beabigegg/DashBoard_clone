# Copy to .env.example and adapt per repository.
# Never put real secrets in this file.

APP_ENV=development
LOG_LEVEL=INFO

# Batch Query Engine — Engine Parallelism (batch-rowcount-unification)
HOLD_ENGINE_PARALLEL=1
JOB_ENGINE_PARALLEL=1
MSD_ENGINE_PARALLEL=1

# Batch Query Engine — Row-Count Chunking (batch-rowcount-unification)
USE_ROW_COUNT_CHUNKING=false
BATCH_QUERY_ROWS_PER_CHUNK=50000

# Unified Query Infrastructure — DuckDB Job Temp Directory (unified-query-core-infra)
# Transient per-job DuckDB files. Sibling of QUERY_SPOOL_DIR. Use absolute path in Docker.
# Default: {QUERY_SPOOL_DIR}/../duckdb_jobs (computed at import as tmp/duckdb_jobs)
DUCKDB_JOB_DIR=tmp/duckdb_jobs

# EAP ALARM Unified Job Path Feature Flag (eap-alarm-unified-job-poc)
# off (default) = legacy run_eap_alarm_query_job; on = unified EapAlarmJob (BaseChunkedDuckDBJob)
# Must be off in production until parity tests pass (AC-1). Restart required.
EAP_ALARM_USE_UNIFIED_JOB=off

# Production History Unified Job Path Feature Flag (production-reject-history-migration)
# off (default) = legacy pandas BQE path; on = unified ProductionHistoryJob (BaseChunkedDuckDBJob)
# always_async=False; sync_fallback_allowed=True. Restart required.
PRODUCTION_HISTORY_USE_UNIFIED_JOB=off

# Reject History Unified Job Path Feature Flag (production-reject-history-migration)
# off (default) = legacy enqueue_reject_query path; on = unified RejectHistoryJob (BaseChunkedDuckDBJob)
# always_async=False; sync_fallback_allowed=True; requires_cross_chunk_reduction=True. Restart required.
REJECT_HISTORY_USE_UNIFIED_JOB=off

# Material Trace Unified Job Path Feature Flag (material-trace-streaming-migration)
# off (default) = legacy _execute_batched_query_to_parquet path; on = unified MaterialTraceJob (BaseChunkedDuckDBJob)
# always_async=True; sync_fallback_allowed=False; async unavailable -> 503 (no sync fallback). Restart required.
MATERIAL_TRACE_USE_UNIFIED_JOB=off

# Downtime Analysis Unified Job Path Feature Flag (downtime-duckdb-join-migration)
# off (default) = legacy _bridge_jobid Path B pd.merge; on = unified DowntimeJob (BaseChunkedDuckDBJob)
# always_async=True; sync_fallback_allowed=False; async unavailable -> 503 (no sync fallback). Restart required.
DOWNTIME_USE_UNIFIED_JOB=off
